FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_PATH=instance/releaseguard.db
APP_VERSION=1.0.0
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15555550100
ALERT_PHONE_NUMBER=+15555550101
# Public URL Twilio calls, used for webhook signature verification.
TWILIO_WEBHOOK_URL=https://example.com/twilio/incoming
# Shared secret for Jenkins POST /api/builds. Leave blank only for local development.
BUILD_API_TOKEN=change-me
RELEASEGUARD_URL=http://127.0.0.1:5000
# Interactive dashboard controls. Set to false in production.
ENABLE_DEMO_CONTROLS=true
